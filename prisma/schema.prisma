generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  FREE
  PRO
  PROFESSIONAL
  STUDIO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BannerStatus {
  PENDING
  COMPLETED
  FAILED
}

enum BannerFormat {
  POST_FEED
  STORY
  SQUARE
  FLYER
}

enum BannerStylePreset {
  NEON_CLUB
  FESTIVAL_MAINSTAGE
  CYBER_RAVE
  DARK_TECHNO
  CHROME_FUTURE
  AFRO_HOUSE_SUNSET
  Y2K_CLUB
  PREMIUM_BLACK
  SUMMER_VIBES
  MINIMAL_TECHNO
  LUXURY_GOLD
}

enum MotionRenderStatus {
  PENDING
  RENDERING
  COMPLETED
  FAILED
}

enum MotionPreset {
  NEON_PULSE
  CLUB_FLASH
  CINEMATIC_ZOOM
  FESTIVAL_LIGHTS
  DARK_TECHNO_GLITCH
}

enum UsageEventType {
  BANNER_GENERATION
  BANNER_VARIATION
  BANNER_EDIT
  BANNER_MOTION_RENDER
  ONBOARDING_TOUR_COMPLETED
}

model User {
  id                          String    @id @default(cuid())
  name                        String?
  email                       String    @unique
  passwordHash                String?
  role                        UserRole  @default(USER)
  isActive                    Boolean   @default(true)
  emailVerifiedAt             DateTime?
  emailVerificationCodeHash   String?
  emailVerificationExpiresAt  DateTime?
  preferredLocale             String    @default("en")
  languageOnboardingCompleted Boolean   @default(false)
  emailVerificationSentAt     DateTime?
  emailVerificationAttempts   Int       @default(0)
  passwordSetupTokenHash      String?
  passwordSetupExpiresAt      DateTime?
  passwordSetupSentAt         DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  workspaces Workspace[]
}

enum UserRole {
  USER
  OWNER
  SUPER_ADMIN
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?
  banners       Banner[]
  motionRenders BannerMotion[]
  assets        Asset[]
  usageEvents   UsageEvent[]
}

model Subscription {
  id                     String             @id @default(cuid())
  workspaceId            String             @unique
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(TRIALING)
  provider               String?            @default("stripe")
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Banner {
  id                String            @id @default(cuid())
  workspaceId       String
  title             String
  djName            String?
  eventName         String?
  eventDate         String?
  eventLocation     String?
  city              String?
  stylePreset       BannerStylePreset
  format            BannerFormat
  prompt            String
  revisedPrompt     String?
  modelName         String
  status            BannerStatus      @default(PENDING)
  referenceImageUrl String?
  outputImageUrl    String?
  width             Int?
  height            Int?
  generationSeconds Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  motionRenders     BannerMotion[]
}

model BannerMotion {
  id                    String             @id @default(cuid())
  workspaceId           String
  bannerId              String
  usageEventId          String?
  preset                MotionPreset
  transitionVariant     String             @default("AUTO")
  status                MotionRenderStatus @default(PENDING)
  inputImageUrl         String
  inputAudioUrl         String?
  inputAudioStorageKey  String?
  audioOriginalName     String?
  audioMimeType         String?
  audioSizeBytes        Int?
  outputVideoUrl        String?
  outputVideoStorageKey String?
  format                BannerFormat
  width                 Int?
  height                Int?
  durationSeconds       Int                @default(10)
  renderProgress        Int                @default(0)
  errorMessage          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  workspace             Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  banner                Banner             @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([bannerId])
  @@index([status, createdAt])
}

model Asset {
  id              String    @id @default(cuid())
  workspaceId     String
  url             String
  originalName    String
  storageProvider String
  storageKey      String?
  mimeType        String?
  sizeBytes       Int?
  width           Int?
  height          Int?
  createdAt       DateTime  @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id          String         @id @default(cuid())
  workspaceId String
  type        UsageEventType
  units       Int            @default(1)
  metadata    Json?
  createdAt   DateTime       @default(now())
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}
